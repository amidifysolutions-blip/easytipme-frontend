rules_version = '2';
// EasyTipMe — Firestore security rules (baseline hardening)
// Replaces open "test mode". Apply in Firebase Console → Firestore → Rules.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'amidifysolutions@gmail.com';
    }

    // Business account (owner) — a shop can be read by its known ID (customer page),
    // but the full list can only be enumerated by the platform admin.
    match /businesses/{uid} {
      allow get: if true;                                   // shop page reads one shop by ID
      allow list: if isAdmin();                             // only admin can query all shops
      allow create, update: if request.auth != null
                            && request.auth.uid == uid;     // owner edits only their own shop
      allow delete: if false;

      // Team members — shown publicly on the tipping page.
      // NOTE: staff docs currently include private fields (real name, email, phone).
      // Before launch we should split these into a private sub-doc so they are NOT public.
      match /staff/{staffId} {
        allow get, list: if true;
        allow create, delete: if request.auth != null && request.auth.uid == uid;   // owner adds/removes
        // Owner can fully edit. A signed-in team member whose email matches the record
        // (and that isn't already claimed by another account) may update ONLY their own
        // claim / self / leave fields — never status, published, email, nickname, etc.
        allow update: if (request.auth != null && request.auth.uid == uid)
          || ( request.auth != null
               && resource.data.email == request.auth.token.email
               && (!('claimedUid' in resource.data) || resource.data.claimedUid == request.auth.uid)
               && request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(['claimedUid','claimedAt','leftByStaff','leftAt','selfFirstName','selfLastName','selfPhone']) );
      }

      // Tips — a customer (unauthenticated) can create one. The owner can read all of
      // their business's tips; a signed-in team member can read only the tips whose
      // recipientEmails array contains their own account email.
      match /tips/{tipId} {
        allow create: if true;
        allow get, list: if (request.auth != null && request.auth.uid == uid)
          || (request.auth != null
              && request.auth.token.email in resource.data.recipientEmails);
        allow update, delete: if false;
      }

      // Tip-sharing consents — a signed-in team member records their own agreement.
      // Owner can read all; a team member can read only their own consent rows.
      match /consents/{consentId} {
        allow create: if request.auth != null
                      && request.resource.data.email == request.auth.token.email;
        allow get, list: if (request.auth != null && request.auth.uid == uid)
          || (request.auth != null && resource.data.email == request.auth.token.email);
        allow update, delete: if false;
      }
    }

    // Platform config (commission, min/max) — readable by everyone, writable by admin only.
    match /config/{docId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

    // Short workplace codes → business id. A staff app reads one by code (public lookup);
    // an owner can only create/edit a code that points to their own business.
    match /shopCodes/{code} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null && request.resource.data.bid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.bid == request.auth.uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
